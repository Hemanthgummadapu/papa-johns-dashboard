# Next.js / Auth
NEXTAUTH_URL=
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=

# Shared Postgres (Railway Postgres addon injects DATABASE_URL)
DATABASE_URL=

# Scraper → Next.js API (optional; scraper uses this to call app routes)
SCRAPER_API_KEY=

# PJ Extranet
PJ_EXTRANET_USERNAME=
PJ_EXTRANET_PASSWORD=

# SMG
SMG_USERNAME=
SMG_PASSWORD=

# Tableau REST API (HotSchedules labor, Leadership, BoZoCoRo)
# TABLEAU_SERVER_URL: base URL only, e.g. https://us-east-1.online.tableau.com (no /#/site/... suffix)
# Set TABLEAU_TOKEN_SECRET (and TABLEAU_TOKEN_NAME, TABLEAU_SITE_NAME) in Railway for papa-johns-dashboard.
TABLEAU_SERVER_URL=
TABLEAU_SITE_NAME=
TABLEAU_TOKEN_NAME=
TABLEAU_TOKEN_SECRET=

# Optional: Supabase (if still used alongside Postgres)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
