# Supabase Configuration
# Get these values from your Supabase project dashboard: https://supabase.com/dashboard

# Public URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anonymous/public key (safe to expose in client-side code)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (keep secret! Only use in server-side code)
# This key has admin privileges and bypasses Row Level Security
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Database connection string (for direct Postgres access)
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Google Sheets Integration (for automation log)
# Get these from Google Cloud Console: https://console.cloud.google.com
# Create a service account and download the JSON key file
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_google_sheet_id_here
